{
  "name": "tradingview-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Local MCP server scaffold for manual TradingView Desktop charting workflows.",
  "type": "module",
  "bin": {
    "tradingview-mcp": "./dist/src/index.js",
    "tradingview-mcp-cli": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/src/index.js",
    "tv:chart": "tsx src/cli.ts chart",
    "test": "npm run build && node --test \"dist/test/**/*.test.js\"",
    "tv:universe": "tsx src/cli.ts universe",
    "tv:health": "tsx src/cli.ts health",
    "tv:launch": "tsx src/cli.ts launch",
    "tv:launch-command": "tsx src/cli.ts launch-command",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.41",
    "@types/ws": "^8.18.1",
    "eslint": "^10.4.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
